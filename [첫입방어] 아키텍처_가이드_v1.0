import com.sun.net.httpserver.HttpExchange;
import com.sun.net.httpserver.HttpHandler;
import com.sun.net.httpserver.HttpServer;
import java.io.IOException;
import java.io.OutputStream;
import java.net.InetSocketAddress;
import java.net.URLDecoder;
import java.nio.charset.StandardCharsets;
import java.util.HashMap;
import java.util.Map;

public class BloodSugarApplication {

    public static void main(String[] args) throws IOException {
        // 8080 포트에서 대기하는 웹 서버 구동
        HttpServer server = HttpServer.create(new InetSocketAddress(8080), 0);
        
        // 4단 구조 API 엔드포인트 매칭
        server.createContext("/api/shield", new ShieldHandler());       // 1번: 첫입방어 쉴드
        server.createContext("/api/rescue", new RescueHandler());       // 2번: SOS 구조대
        server.createContext("/api/mart", new MartHandler());           // 3번: 매점/마트 꿀템
        server.createContext("/api/report", new ReportHandler());       // 4번: 내 몸 리포트

        server.setExecutor(null);
        System.out.println("🚀 [첫입방어] 백엔드 엔진 구동 시작! (http://localhost:8080)");
        server.start();
    }

    // CORS 및 OPTIONS 예비 요청 공통 처리 메서드
    private static boolean handleCorsAndOptions(HttpExchange exchange) throws IOException {
        exchange.getResponseHeaders().add("Access-Control-Allow-Origin", "*");
        exchange.getResponseHeaders().add("Access-Control-Allow-Methods", "GET, OPTIONS");
        exchange.getResponseHeaders().add("Access-Control-Allow-Headers", "Content-Type");

        if ("OPTIONS".equalsIgnoreCase(exchange.getRequestMethod())) {
            exchange.sendResponseHeaders(204, -1);
            return true;
        }
        return false;
    }

    // JSON 응답 전송 공통 메서드
    private static void sendJsonResponse(HttpExchange exchange, String jsonResponse) throws IOException {
        byte[] responseBytes = jsonResponse.getBytes(StandardCharsets.UTF_8);
        exchange.getResponseHeaders().set("Content-Type", "application/json; charset=UTF-8");
        exchange.sendResponseHeaders(200, responseBytes.length);
        try (OutputStream os = exchange.getResponseBody()) {
            os.write(responseBytes);
        }
    }

    // URL 쿼리 파라미터 파싱 유틸리티
    private static Map<String, String> parseQuery(String query) {
        Map<String, String> result = new HashMap<>();
        if (query == null) return result;
        for (String param : query.split("&")) {
            String[] entry = param.split("=");
            if (entry.length > 1) {
                result.put(
                    URLDecoder.decode(entry[0], StandardCharsets.UTF_8), 
                    URLDecoder.decode(entry[1], StandardCharsets.UTF_8)
                );
            }
        }
        return result;
    }

    // ==========================================
    // 1번 카테고리 Handler: 첫입방어 쉴드
    // ==========================================
    static class ShieldHandler implements HttpHandler {
        @Override
        public void handle(HttpExchange exchange) throws IOException {
            if (handleCorsAndOptions(exchange)) return;

            if ("GET".equalsIgnoreCase(exchange.getRequestMethod())) {
                Map<String, String> params = parseQuery(exchange.getRequestURI().getQuery());
                String firstBite = params.getOrDefault("firstBite", "");

                String status;
                String tip;

                if ("CARB".equals(firstBite)) { // 밥/면 먼저
                    status = "위험 지수 최고조 (폭우 에러) 🚨";
                    tip = "잠깐! 빈속에 탄수화물은 혈당 소나기를 유발해요. 계란후라이나 두부 한 조각이라도 먼저 입에 넣어 방어막을 치세요!";
                } else if ("MEAT".equals(firstBite)) { // 고기/계란 먼저
                    status = "중간 방어막 가동 (안전) 💛";
                    tip = "좋은 선택입니다! 단백질과 지방이 위벽을 먼저 감싸주어 혈당이 치솟는 속도를 늦춰줍니다.";
                } else if ("VEGE".equals(firstBite)) { // 채소 먼저
                    status = "완벽한 철벽 쉴드 (최고) 💚";
                    tip = "환상적입니다! 채소의 식이섬유가 장에 그물망을 쳐서 이후에 들어올 탄수화물의 흡수를 완벽히 지연시킵니다.";
                } else {
                    status = "대기 중";
                    tip = "오늘 첫 입으로 드실 음식을 3초 만에 툭 선택해 주세요!";
                }

                String json = String.format("{\"status\": \"%s\", \"tip\": \"%s\"}", status, tip);
                sendJsonResponse(exchange, json);
            }
        }
    }

    // ==========================================
    // 2번 카테고리 Handler: 지금 당장! 구조대 (SOS)
    // ==========================================
    static class RescueHandler implements HttpHandler {
        @Override
        public void handle(HttpExchange exchange) throws IOException {
            if (handleCorsAndOptions(exchange)) return;

            if ("GET".equalsIgnoreCase(exchange.getRequestMethod())) {
                Map<String, String> params = parseQuery(exchange.getRequestURI().getQuery());
                String situation = params.getOrDefault("situation", "");

                String tip;
                if ("COMPANY".equals(situation)) {
                    tip = "👥 [회식 자리] 메뉴 선택권이 없나요? 중식당이라면 짜장면을 비비기 전에 반찬으로 나온 '양파'를 춘장에 찍어 먼저 드세요! 고깃집이라면 찌개 대신 고기쌈의 상추를 먼저 2장 크게 싸서 드시는 것이 치트키입니다.";
                } else if ("HOSPITAL".equals(situation)) {
                    tip = "🏥 [병원/실내 간식] 몸을 움직이기 힘든 상황인가요? 간식이 당길 땐 빵 대신 구운 계란이나 무가당 두유를 선택하세요. 음식을 먹은 뒤 앉아있기보다는 제자리에서 발뒤꿈치 들기 운동을 20회만 해주셔도 혈당이 뚝 떨어집니다.";
                } else {
                    tip = "상황을 선택하시면 꼼짝 못 하는 상황 속 '잔소리 없는 현실적 탈출 꿀팁'을 보여드립니다.";
                }

                String json = String.format("{\"tip\": \"%s\"}", tip);
                sendJsonResponse(exchange, json);
            }
        }
    }

    // ==========================================
    // 3번 카테고리 Handler: 매점/마트 꿀템 (오후 4시 알람)
    // ==========================================
    static class MartHandler implements HttpHandler {
        @Override
        public void handle(HttpExchange exchange) throws IOException {
            if (handleCorsAndOptions(exchange)) return;

            if ("GET".equalsIgnoreCase(exchange.getRequestMethod())) {
                String json = "{"
                    + "\"time\": \"오후 4:00 마의 시간대 ⏰\","
                    + "\"alarm\": \"출출하시죠? 입터짐 방지 편의점 레이더 가동!\","
                    + "\"item1\": \"스트링 치즈 (당류 0g / 단백질 단단)\","
                    + "\"item2\": \"아몬드 한 줌 + 무가당 아몬드 브리즈\","
                    + "\"item3\": \"프로틴 바 (성분표 뒤쪽 '당류' 동그라미 확인! 5g 이하 꿀템)\""
                    + "}";
                sendJsonResponse(exchange, json);
            }
        }
    }

    // ==========================================
    // 4번 카테고리 Handler: 내 몸 리포트
    // ==========================================
    static class ReportHandler implements HttpHandler {
        @Override
        public void handle(HttpExchange exchange) throws IOException {
            if (handleCorsAndOptions(exchange)) return;

            if ("GET".equalsIgnoreCase(exchange.getRequestMethod())) {
                String json = "{"
                    + "\"rate\": \"80%\","
                    + "\"improvement\": \"식후 졸림/피로 발생 횟수 지난주 대비 3회 감소! 🎉\","
                    + "\"detective\": \"🕵️‍♂️ 탐정 리포트: 유저님이 '채소 먼저'를 실행한 날은 오후 2시 식곤증 증상이 기적적으로 나타나지 않았습니다. 몸이 가벼워진 진짜 변화를 체감해 보세요!\""
                    + "}";
                sendJsonResponse(exchange, json);
            }
        }
    }
}
